@startuml VesselRecordContainers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

Person(user, "Port Authority Officer", "System user managing vessel records")

System_Boundary(system, "Vessel Record Management System") {
Container(api, "Vessel Record API", ".NET 8 (ASP.NET Core Web API)", "Provides endpoints to manage vessel Records (create, update, list)")
ContainerDb(db, "ShippingManagement Database", "SQLite", "Stores vessel record information (IMO number, vessel name, vessel type, etc.)")
}

Rel(user, api, "Sends HTTP requests via ...", "HTTPS/JSON")
Rel(api, db, "Reads from and writes to", "EF Core/SQL")

@enduml