@startuml VesselTypeContainers
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

Person(user, "Port Authority Officer", "System user managing vessel types")

System_Boundary(system, "Vessel Type Management System") {
Container(api, "Vessel Type API", ".NET 8 (ASP.NET Core Web API)", "Provides endpoints to manage vessel types (create, update, delete, list)")
ContainerDb(db, "ShippingManagement Database", "SQLite", "Stores vessel type information (name, capacity, dimensions, etc.)")
}

Rel(user, api, "Sends HTTP requests via Swagger or Postman", "HTTPS/JSON")
Rel(api, db, "Reads from and writes to", "EF Core/SQL")

@enduml