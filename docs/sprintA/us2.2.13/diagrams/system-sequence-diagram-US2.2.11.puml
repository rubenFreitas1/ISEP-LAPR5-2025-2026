@startuml 2.2.11
skinparam monochrome true
skinparam packageStyle rectangle
skinparam shadowing false

actor "Logistics Operator" as LogisticsOperator
participant "System" as system

title System Sequence Diagram - US2.2.11

== Register a staff menber ==
activate LogisticsOperator

LogisticsOperator -> system : Asks to register staff menbers
activate system

system --> LogisticsOperator : Request staff menber information("ID, Short Name,\n Email, Phone, Qualifications, Operations Window, Status")
deactivate system
LogisticsOperator -> system : Types request data

activate system
system --> LogisticsOperator : Request the Vessel Types allowed to berth in the dock
deactivate system




@enduml
